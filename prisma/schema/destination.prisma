model Destination {
  id                 Int       @id @default(autoincrement())
  address            String?  
  addressLink        String?
  floor_unit         String?   @db.VarChar(100)
  contact_name       String?   @db.VarChar(100)
  contact_number     String?   @db.VarChar(20)
  note_to_driver     String?
  is_saved           Boolean   @default(false)
  type               DestinationType?
  latitude  Decimal?  @db.Decimal(10,7)
  longitude Decimal?  @db.Decimal(10,7)
  accuracy  Float?
  
  user_id            Int
  user               User @relation(fields: [user_id], references: [id], onDelete:Cascade)
  // 
  order_id           Int?
  order              Order? @relation(fields: [order_id], references: [id], onDelete:SetNull)
   
  service_zoneId     Int?
  serviceZone        serviceZone? @relation(fields: [service_zoneId], references: [id])

  @@map("destinations")
}
