model Order {
  id Int @id @default(autoincrement())

  serviceZoneId Int?
  serviceZone   serviceZone? @relation(fields: [serviceZoneId], references: [id], onDelete: SetNull)

  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId Int?

  route_type       RouteType    @default(ONE_WAY)
  delivery_type_id Int
  delivery_type    DeliveryType @relation(fields: [delivery_type_id], references: [id], onDelete: SetNull)

  pay_type       PayType     @default(WALLET)
  collect_time   CollectTime @default(ASAP)
  scheduled_time DateTime?

  vehicle_type_id Int?
  vehicle         VehicleType? @relation(fields: [vehicle_type_id], references: [id], onDelete: SetNull)

  // 
  useCoins       Boolean @default(false)
  originalCost   Decimal @default(0) @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  coinsRedeemed  Int     @default(0)
  promoCode      String?
  promoDiscount  Decimal @default(0) @db.Decimal(12, 2)

  total_cost              Decimal  @db.Decimal(12, 2)
  total_fee               Decimal? @db.Decimal(12, 2)
  additional_cost         Decimal? @db.Decimal(12, 2)
  commission              Decimal? @db.Decimal(12, 2)
  refund_amount           Decimal? @db.Decimal(12, 2)
  has_additional_services Boolean  @default(false)
  notify_favorite_raider  Boolean  @default(false)

  payment_method_id Int?
  payment_method    PaymentMethod? @relation(fields: [payment_method_id], references: [id], onDelete: SetNull)

  compititor_id          Int[]     @default([])
  competition_started_at DateTime?
  competition_closed     Boolean   @default(false)

  assign_rider_id Int?
  assign_rider    Raider? @relation("AssignedRaider", fields: [assign_rider_id], references: [id], onDelete: SetNull)

  //
  isPriorited          Boolean     @default(false)
  priorityAt           DateTime?
  raider_confirmation  Boolean     @default(false)
  is_auto_confirmation Boolean     @default(false)
  is_reviewed          Boolean     @default(false)
  is_placed            Boolean     @default(false)
  is_pickup            Boolean     @default(false)
  order_status         OrderStatus @default(PROGRESS)
  is_out_for_delivery  Boolean     @default(false)
  isFixed              Boolean     @default(true)
  isDispute            Boolean     @default(false)
  isBulk               Boolean     @default(false)
  total_distance       Decimal     @default(0) @db.Decimal(12, 2)

  transactions Transaction[]
  declines     OrderDecline[]
  orderStops   OrderStop[]

  rewards       Reward[]
  // 
  rate_raiders        RateRaider?
  rate_customers      RateCustomer?
  tips                Tip[]
  dispute             Dispute?
  additional_services Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([userId, order_status])
  @@map("orders")
}
