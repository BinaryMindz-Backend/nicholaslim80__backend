model Dispute {
  id Int @id @default(autoincrement())

  orderId Int?
  order   Order? @relation(fields: [orderId], references: [id])

  // Customer
  userId Int?
  user   User? @relation("UserDisputes", fields: [userId], references: [id])

  // Rider
  riderId Int?
  rider   User? @relation("RiderDisputes", fields: [riderId], references: [id])

  // Admin resolver
  resolvedByAdminId Int?
  resolvedByAdmin   User? @relation("ResolvedDisputes", fields: [resolvedByAdminId], references: [id])

  // Dynamic dispute type
  disputeTypeId String
  disputeType   DisputeType @relation(fields: [disputeTypeId], references: [id])

  description String?

  priority DisputePriority
  status   DisputeStatus   @default(PENDING)

  evidence String[]

  refundType     String?
  refundAmount   Decimal? @db.Decimal(12, 2)
  companyPercent Int?
  riderPercent   Int?

  resolvedAt DateTime?
  adminNote  String?

  is_closed Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([riderId])
  @@index([disputeTypeId])
}

model DisputeType {
  id       String          @id @default(cuid())
  name     String
  role     DisputeRole
  priority DisputePriority @default(LOW)
  isActive Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disputes Dispute[]
}
