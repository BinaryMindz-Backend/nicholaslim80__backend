// prisma/models/dispute.prisma

model Dispute {
  id                      Int       @id @default(autoincrement())
  case_id                 Int    @unique
  order                   Order  @relation("OrderDispute", fields: [case_id], references: [id], onDelete: Cascade)
  username                String?
  issueType               String?   // DAMAGE_GOODS, MISSING_ITEMS
  issue_date              DateTime?
  service_area_latitude   Decimal?  @db.Decimal(10,7)
  service_area_longitude  Decimal?  @db.Decimal(10,7)
  category                String?   // EXPRESS, STANDARD, STACK
  priority                String?   // HIGH, MEDIUM, LOW
  notes                   String?
  isRefund                Boolean   @default(false)
  total                   Decimal?  @db.Decimal(12,2)
  evidence_attach         Json?
  isClosed                Boolean   @default(false)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
   
  @@index([case_id])
  @@map("disputes")
}
