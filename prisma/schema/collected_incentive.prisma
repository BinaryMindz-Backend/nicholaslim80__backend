// prisma/models/incentive.prisma

model CollectedIncentive {
  id               Int            @id @default(autoincrement())
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          Int?
  incentive       Incentive?    @relation(fields: [incentiveId], references: [id], onDelete: SetNull)
  incentiveId     Int?
  amount Int? @default(0)
  is_collected Boolean @default(false)
  created_at       DateTime       @default(now())

  @@map("collected_incentives")
}
