// prisma/models/coinHistory.prisma

model CoinHistory {
  id                   Int         @id @default(autoincrement())
  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               Int
  username             String?
  total_coin_acc       Decimal?    @db.Decimal(12,2)
  type                 CoinHistoryType
  total_coin_apply     Decimal?    @db.Decimal(12,2)
  current_coin_balance Decimal?    @db.Decimal(12,2)
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt
  reward               Reward[]

  @@map("coin_history")
}
