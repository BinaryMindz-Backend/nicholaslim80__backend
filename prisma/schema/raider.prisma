model Raider {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  is_online    Boolean @default(false)
  is_available Boolean @default(false)

  raider_status                RaiderStatus       @default(IN_ACTIVE)
  LoginType                    LoginType          @default(DIRECT_SIGNIN)
  raider_verificationFromAdmin RaiderVerification @default(PENDING)

  // Financial / status
  is_deposit_made Boolean @default(false)

  isSuspended       Boolean   @default(false)
  suspendedDuration DateTime?
  suspensionReason  String?

  // Branding / premium
  hasBranding      Boolean @default(false)
  hasAdDecal       Boolean @default(false)
  isPremium        Boolean @default(false)
  reviews_count    Int     @default(0)
  completed_orders Int     @default(0)
  active_days      Int     @default(0)

  avg_rating        Decimal @default(0) @db.Decimal(3, 2)
  completion_rate   Float   @default(100)
  cancellation_rate Float   @default(0)
  acceptance_rate   Float   @default(100)
  driverScore       Float   @default(0)

  isGoldOptedIn     Boolean @default(false)
  weeklyActiveHours Float   @default(0)

  tierId Int?
  tier   DriverTier? @relation(fields: [tierId], references: [id])

  raiderTierHistories RaiderTierHistory[]
  lastDeliveryAt      DateTime?
  lastOrderAssignedAt DateTime?

  //auto popup
  isAutoPopUpEnabled Boolean @default(false)
  distanceInRadius   Int     @default(5)

  manualTierOverride Boolean   @default(false)
  manualTierId       Int?
  manualTierUntil    DateTime?

  registrations       RaiderRegistration[]
  locations           RaiderLocation?
  locationHistory     RaiderLocationHistory[]
  raiderQuizzes       RaiderQuiz[]
  tips                Tip[]
  followers           myRaider[]
  customer_ratings    RateCustomer[]
  raider_ratings      RateRaider[]
  assignedOrders      Order[]                 @relation("AssignedRaider")
  declines            OrderDecline[]
  raiderOnlineSession RaiderOnlineSession[]
  // wallet addjustments for raider (admin adjustments to raider wallet)
  adjustments         WalletAdjustment[]
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
}
