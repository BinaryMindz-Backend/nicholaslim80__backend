model DisputeAppeal {
    id             Int     @id @default(autoincrement())
    orderDisputeId Int
    orderId        Int
    reason         String  @db.Text
    fileUrl        String?

    // Add these
    status            AppealStatus @default(PENDING)
    adminNote         String?      @db.Text
    resolvedByAdminId Int?
    resolvedAt        DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    orderDispute    Dispute @relation(fields: [orderDisputeId], references: [id], onDelete: Cascade)
    order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    resolvedByAdmin User?   @relation("ResolvedDisputeAppeals", fields: [resolvedByAdminId], references: [id])
    user            User?   @relation(fields: [userId], references: [id])
    userId          Int?

    @@index([orderDisputeId])
    @@index([orderId])
    @@map("dispute_appeals")
}
