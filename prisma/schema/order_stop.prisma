model OrderStop {
  id Int @id @default(autoincrement())

  // Order Link
  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Destination Reference (allows reuse)
  destinationId Int
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Restrict)

  // Snapshot of destination data
  address        String
  latitude       Float
  longitude      Float
  additionalInfo String?

  // Stop Details
  type     StopType
  sequence Int
  status   StopStatus @default(PENDING)

  // Rider Step Tracking
  proceed_to_pickup Boolean @default(false)
  is_arrived        Boolean @default(false)
  is_load           Boolean @default(false)
  is_unload         Boolean @default(false)
  is_skiped         Boolean @default(false)

  // price snapshot
  calculated_price    Decimal?  @default(0) @db.Decimal(12, 2)
  calculated_distance Decimal?  @default(0) @db.Decimal(10, 4)
  calculated_time     Int?
  calculated_time_txt String?
  // Timestamps
  proceedAt           DateTime?
  arrivedStepAt       DateTime?
  loadedAt            DateTime?
  unloadedAt          DateTime?

  // Delivery Proof
  proofs String[] @default([])
  notes  String?

  // Timestamps
  arrivedAt     DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  // Payment
  payment StopPayment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId, sequence])
  @@index([orderId, status])
  @@map("order_stops")
}
