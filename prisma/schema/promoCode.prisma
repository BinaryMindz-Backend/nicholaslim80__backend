model PromoCode {

      id             Int @id @default(autoincrement())
      promoCode      String @unique
      discountType   DiscountType
      discountValue  Int
      discountDesc   String 
      redirectLink   String

      isActive       Boolean @default(false)
       
      expires_at     DateTime 

      created_at     DateTime       @default(now())
      updated_at     DateTime       @updatedAt
      promaCodeUses  PromaCodeUses[]

}


