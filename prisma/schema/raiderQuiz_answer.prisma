model RaiderQuiz {
  id              Int      @id @default(autoincrement())
  
  raider          Raider   @relation(fields: [raiderId], references: [id], onDelete: Cascade)
  raiderId        Int
  
  quiz            Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId          Int
  total_questions Int @default(0)
  correct_answers Int @default(0)
  score           Int @default(0)
  attempt_count   Int @default(1)          
  completed_at    DateTime? @default(now())
  raiderAnswers     RaiderAnswer[]
  @@map("raider_quizzes")
}

model RaiderAnswer {
  id                Int       @id @default(autoincrement())

  raider_quiz         RaiderQuiz  @relation(fields: [raider_quiz_id], references: [id], onDelete: Cascade)
  raider_quiz_id      Int
  
  question          Question  @relation(fields: [question_id], references: [id], onDelete: Cascade)
  question_id       Int   @unique 
  
  selected_option   Option?   @relation(fields: [selected_option_id], references: [id], onDelete: SetNull)
  selected_option_id Int?   @unique
  is_correct        Boolean

  @@map("raider_answers")
}
