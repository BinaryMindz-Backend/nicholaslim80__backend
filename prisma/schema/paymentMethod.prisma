model PaymentMethod {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  stripeMethodId String
  type           String?   // "card", "apple_pay", etc.
  last4          String?
  expMonth       Int?
  expYear        Int?
  isDefault      Boolean  @default(false)

  order        Order[]
  //transaction
  transactions   Transaction[] 


  @@map("payment_methods")
}
