model VehicleType {
  id           Int             @id @default(autoincrement())
  vehicle_type VehicleTypeEnum
  base_price   Decimal?        @db.Decimal(12, 2)
  per_km_price Decimal?        @db.Decimal(12, 2)
  peak_pricing Boolean         @default(false)
  dimension    String?
  max_load     Decimal?        @db.Decimal(12, 2)
  isActive     Boolean         @default(true)

  orders Order[]

  @@map("vehicle_types")
}
