model RaiderRegistration {
  id                          Int       @id @default(autoincrement())

  raider                      Raider    @relation(fields: [raiderId], references: [id], onDelete: Cascade)
  raiderId                    Int @unique
  
  raider_verificationFromAdmin         RaiderVerification @default(PENDING)

  // Personal
  raider_name                 String
  contact_number              String
  email_address               String
  dob                         DateTime
  gender                      Gender
  driver_photos               String[]    
  emergency_contact_name      String
  emergency_contact_number    String

  // Identity
  identity_card_number        String
  nid_front_images            String
  nid_back_images             String
  driving_license_number      String
  driving_license_issue_date  DateTime
  driving_license_expire_date DateTime
  driving_license_front_images String
  driving_license_back_images  String

  // Vehicle
  vehicle_plate_number        String
  vehicle_type                VehicleTypeEnum
  vehicle_brand               String
  registration_date           DateTime
  vehicle_front_images        String
  vehicle_back_images         String
  vehicle_driver_side_images  String
  vehicle_passenger_side_images String

  // Log & Insurance
  vehicle_log_number          String
  vehicle_log_issue_date      DateTime
  vehicle_log_expire_date     DateTime
  vehicle_log_images          String
  vehicle_policy_number       String
  vehicle_policy_issue_date   DateTime
  vehicle_policy_expire_date  DateTime
  vehicle_policy_images       String
  
  // Address
  current_address             String
  current_apartment           String
  current_state_province     String
  current_city                String
  current_country             String
  current_zip_post_code       String

  permanent_address           String
  permanent_apartment         String
  permanent_state_province    String
  permanent_city              String
  permanent_country           String
  permanent_zip_post_code     String


  signInPortal   PortalEnum
  isSuspended    Boolean   @default(false)
  suspendedDuration  DateTime?
  suspensionReason   String?
  bank_name                   String
  account_number              String

  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @updatedAt

  @@map("raider_registrations")
}
