model RaiderRegistration {
  id Int @id @default(autoincrement())

  raider   Raider @relation(fields: [raiderId], references: [id], onDelete: Cascade)
  raiderId Int    @unique

  // ---------------- PERSONAL ----------------
  raider_name              String
  contact_number           String
  email_address            String
  dob                      DateTime
  gender                   Gender
  driver_photos            String[]
  emergency_contact_name   String
  emergency_contact_number String

  // ---------------- IDENTITY ----------------
  identity_card_number     String
  identity_card_issue_date DateTime

  nric_front_images String
  nric_back_images  String

  // ---------------- DRIVING LICENSE ----------------
  driving_license_number      String
  driving_license_issue_date  DateTime
  driving_license_expire_date DateTime

  license_class LicenseClass

  driving_license_front_images String
  driving_license_back_images  String

  // ---------------- VEHICLE ----------------
  vehicle_plate_number String

  vehicle_type_id Int
  vehicle_type    VehicleType @relation(fields: [vehicle_type_id], references: [id])

  vehicle_brand String
  vehicle_model String

  registration_date DateTime

  vehicle_front_images          String
  vehicle_back_images           String
  vehicle_driver_side_images    String
  vehicle_passenger_side_images String

  // ---------------- LOG ----------------
  chassis_number     String
  vehicle_log_images String

  // ---------------- INSURANCE ----------------
  insurance_policy_number String
  insurance_issue_date    DateTime
  insurance_expiry_date   DateTime
  insurance_policy_images String

  // ---------------- CURRENT ADDRESS ----------------
  current_postal_code String
  current_address     String
  current_unit        String?

  current_country String @default("Singapore")

  // ---------------- PERMANENT ADDRESS ----------------
  permanent_postal_code String
  permanent_address     String
  permanent_unit        String?

  permanent_country String @default("Singapore")

  // ---------------- BANK ----------------
  bank_name      String?
  account_number String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("raider_registrations")
}
