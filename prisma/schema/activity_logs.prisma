model ActivityLog {
    id          Int    @id @default(autoincrement())
    action      String // CREATE, UPDATE, DELETE
    entity_type String // 
    entity_id   Int
    user_id     Int

    // store changes or payload
    meta Json?

    created_at DateTime @default(now())

    @@index([entity_type, entity_id])
    @@index([user_id])
}
