model UserLogin {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginAt   DateTime @default(now())
  ip        String?
  device    String?
  logoutAt DateTime?
  durationInMinutes Int?  // optional: store session length

  @@index([userId, loginAt])
}
