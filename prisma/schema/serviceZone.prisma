model serviceZone {
  id              Int      @id @default(autoincrement())
  name            String
  zoneName        String
  coordinates     Json
  deliveryFee     Float // multiplier
  priority        Int?
  color           String?
  minOrderAmmount Float?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 
  orders                      Order[]
  //
  standardCommissionRateZones StandardCommissionRateZone[]
  raiderCompensationRoleZones RaiderCompensationRoleZone[]
  raiderDeductionFeeZones     RaiderDeductionFeeZone[]
  userFeeStructureZones       UserFeeStructureZone[]
  userDynamicSurgeZones       UserDynamicSurgeZone[]

  // Incentives linked to this zone
  incentives        Incentive[]            @relation("IncentiveZones")
  //
  surgePricingRules SurgePricingRuleZone[]

  destinations Destination[]
}
