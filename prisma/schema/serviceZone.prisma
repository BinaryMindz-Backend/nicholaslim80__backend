model serviceZone {
  id              Int      @id @default(autoincrement())
  name            String
  zoneName        String
  coordinates     Json
  deliveryFee     Float
  priority        Int?
  color           String?
  minOrderAmmount Float?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 
  orders          Order[]

  destinations    Destination[]
}
