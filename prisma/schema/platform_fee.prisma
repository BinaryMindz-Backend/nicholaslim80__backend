model StandardCommissionRate {
  id                         Int       @id @default(autoincrement())
  applicable_user            ApplicableTyp
  role_name                  String    @db.VarChar(100)
  commission_rate_delivery_fee Int     @default(0)
  service_area_id            Int?    
  serviceArea                serviceZone? @relation(fields: [service_area_id], references: [id])
  

  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt
}

model RaiderCompensationRole {
  id                         Int       @id @default(autoincrement())
  applicable_user            ApplicableTyp
  scenario                   String    @db.VarChar(100)
  commission_rate_delivery_fee Int     @default(0)
  service_area_id            Int?     
  serviceArea                serviceZone? @relation(fields: [service_area_id], references: [id])

  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt
}

model RaiderDeductionFee {
  id              Int       @id @default(autoincrement())
  applicable_user ApplicableTyp
  deduction_name  String    @db.VarChar(100)
  amount          Int       @default(0)

  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}



model UserFeeStructure {
  id               Int      @id @default(autoincrement())

  applicable_user  ApplicableTyp   // USER | RAIDER | ADMIN (can also be enum if fixed)

  fee_name         String   @db.VarChar(100)

  amount           Int      @default(0)

  service_area_id  Int?
  serviceArea      serviceZone? @relation(fields: [service_area_id], references: [id])

  /// FULLY DYNAMIC RULE SYSTEM
  applies_to       String   // e.g. "ALL_ORDERS", "ORDER_LESS", "DELIVERY_TYPE"

  rule_key         String?  // e.g. "delivery_type", "order_amount", "distance"
  rule_operator    String?  // e.g. "=", "<", ">", "<=", ">="
  rule_value       String?  // stored as string (parse when needed)

  condition_value  Float?   // optional fallback numeric

  is_active        Boolean  @default(true)

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model UserDynamicSurge {
  id                Int       @id @default(autoincrement())
  applicable_user   ApplicableTyp
  role_name         String    @db.VarChar(100)
  price_multiplier  Int       @default(0)
  condition         Condition
  time_range        String    @db.VarChar(100) 
  is_active         Boolean @default(true)

  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
}

