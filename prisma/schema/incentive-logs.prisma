model IncentiveLog {
  id            Int      @id @default(autoincrement())
  incentiveId   Int?

  // Store entire incentive snapshot, including rules, reward, claim, etc.
  incentiveData Json

  // Who made the change
  changedByRole    String
  changedByAdminId Int?

  createdAt     DateTime @default(now())

  // Relation
  incentive Incentive? @relation(fields: [incentiveId], references: [id], onDelete: SetNull)

  @@index([incentiveId])
  @@index([createdAt])
  @@map("incentive_logs")
}